# AI Provider — openai | anthropic | mock (default: openai)
AI_PROVIDER=openai

# Required when AI_PROVIDER=openai (or AI_FALLBACK_PROVIDER=openai)
OPENAI_API_KEY=sk-proj-...

# Required when AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: fill TTS/STT gaps when primary provider lacks them (e.g. anthropic)
# AI_FALLBACK_PROVIDER=openai

# Optional: override specific models
# OPENAI_EXTRACTION_MODEL=gpt-4o
# OPENAI_GRADING_MODEL=gpt-4o-mini
# ANTHROPIC_EXTRACTION_MODEL=claude-opus-4-5
# ANTHROPIC_GRADING_MODEL=claude-haiku-4-5

# Optional: dedicated TTS provider (default: same as AI_PROVIDER)
# Set to "elevenlabs" for significantly more natural-sounding voice.
# TTS_PROVIDER=elevenlabs

# ElevenLabs — required when TTS_PROVIDER=elevenlabs
# Get your API key at https://elevenlabs.io
# ELEVENLABS_API_KEY=sk_...
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # Rachel (default) — browse voices at elevenlabs.io/voice-library
# ELEVENLABS_MODEL=eleven_multilingual_v2     # handles EN + ES automatically

# Optional: OpenAI TTS fallback voice and quality (used when TTS_PROVIDER=openai)
# Models: tts-1 (faster, cheaper) | tts-1-hd (higher quality)
# Voices: alloy | echo | fable | onyx | nova | shimmer
# OPENAI_TTS_MODEL=tts-1-hd
# OPENAI_TTS_VOICE=nova

PORT=3001

# Optional: route all AI API calls through an HTTP/HTTPS proxy
# Direct proxy:  HTTPS_PROXY=http://proxy.example.com:8080
# PAC file:      HTTPS_PROXY=pac+http://pac.example.com/proxy.pac
HTTPS_PROXY=pac+http://pac.tsl.telus.com/standard.pac
